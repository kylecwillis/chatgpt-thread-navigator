{
  "manifest_version": 3,
  "name": "ChatGPT Thread Navigator",
  "short_name": "ThreadNav",
  "version": "0.2.0",
  "description": "A floating outline for long ChatGPT conversations. Lists every question and assistant heading. Click to jump.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
